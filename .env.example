# ============================================
# GEMINI AI API KEYS
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_API_KEY=your-google-genai-api-key-here

# ============================================
# SMTP EMAIL CONFIGURATION
# ============================================

# SMTP Server Hostname
# Gmail: smtp.gmail.com
# Outlook: smtp-mail.outlook.com
# Yahoo: smtp.mail.yahoo.com
SMTP_HOST=smtp.gmail.com

# SMTP Port
# 465 - SSL/TLS (recommended for Gmail)
# 587 - STARTTLS (recommended for Outlook)
SMTP_PORT=465

# Your email address
SMTP_USER=your-email@gmail.com

# For Gmail: Use App Password (16 characters, no spaces)
# Generate at: https://myaccount.google.com/apppasswords
# For other providers: Use your email password or app-specific password
SMTP_PASS=your-app-password-here

# The "From" name and email for sent emails
SMTP_FROM="Wallet Tally <your-email@gmail.com>"

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 
# 1. Copy this file to .env
# 2. Replace all placeholder values with your actual credentials
# 3. For Gmail users:
#    - Enable 2-Step Verification
#    - Generate App Password at https://myaccount.google.com/apppasswords
#    - Use the App Password (not your regular Gmail password)
# 4. Test your configuration: node test-email.js
# 5. Never commit .env to version control!
#
# For detailed setup instructions, see SMTP_SETUP_GUIDE.md
